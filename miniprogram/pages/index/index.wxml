<view class="container">
  <picker mode="selector" range="{{ageOptions}}" value="{{ageIndex}}" bindchange="onAgeChange">
    <view class="picker-box">年龄：{{ageOptions[ageIndex]}}</view>
  </picker>

  <picker mode="selector" range="{{incomeOptions}}" value="{{incomeIndex}}" bindchange="onIncomeChange">
    <view class="picker-box">收入：{{incomeOptions[incomeIndex]}}</view>
  </picker>

  <picker mode="selector" range="{{durationOptions}}" value="{{durationIndex}}" bindchange="onDurationChange">
    <view class="picker-box">时长：{{durationOptions[durationIndex]}}</view>
  </picker>

  <picker mode="selector" range="{{styleOptions}}" value="{{styleIndex}}" bindchange="onStyleChange">
    <view class="picker-box">风格：{{styleOptions[styleIndex]}}</view>
  </picker>

  <view wx:if="{{!list.length}}" class="card sub">暂无匹配路线，去发布一条吧。</view>

  <view wx:for="{{list}}" wx:key="id" class="card" bindtap="goDetail" data-id="{{item.id}}">
    <image wx:if="{{item.cover}}" src="{{item.cover}}" mode="aspectFill" style="width:100%;height:260rpx;border-radius:12rpx;margin-bottom:12rpx;"></image>
    <view class="title">{{item.title}}</view>
    <view class="sub" style="margin-top:8rpx;">{{item.duration}} · {{item.budget}} · {{item.style}}</view>
    <view class="sub">{{item.ageRange}} · {{item.incomeRange}} · {{item.createdAt}}</view>
    <view class="tags">
      <view class="tag" wx:for="{{item.spots}}" wx:key="index">{{item.type}}</view>
    </view>
    <view class="sub" style="margin-top:8rpx;">👀{{item.views}}  ⭐{{item.favorites}}  💬{{item.comments}}</view>
  </view>
</view>
