<view class="container">
  <view class="card">
    <view class="title" style="font-size:30rpx;">我收藏的路线</view>
    <view wx:if="{{!favRoutes.length}}" class="sub" style="margin-top:10rpx;">还没有收藏</view>
    <view wx:for="{{favRoutes}}" wx:key="id" style="padding:14rpx 0;border-top:1rpx solid #f2f2f2;" bindtap="goDetail" data-id="{{item.id}}">
      <view style="font-weight:600;">{{item.title}}</view>
      <view class="sub">{{item.duration}} · {{item.budget}} · {{item.style}}</view>
    </view>
  </view>
</view>
