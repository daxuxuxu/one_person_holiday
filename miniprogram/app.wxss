page {
  background: #f5f7fb;
  color: #222;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
}

.sub {
  color: #666;
  font-size: 24rpx;
}

.input, .textarea, .picker-box {
  background: #fff;
  border-radius: 12rpx;
  padding: 18rpx;
  margin-bottom: 14rpx;
}

.btn-main {
  background: #07c160 !important;
  color: #fff !important;
  border-radius: 12rpx !important;
  border: none !important;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.tag {
  background: #eaf9f0;
  color: #07c160;
  font-size: 22rpx;
  border-radius: 999rpx;
  padding: 6rpx 12rpx;
}
